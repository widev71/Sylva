settings.json           # berisi data profil pribadi (social media, monitor setup, dll)

# ──────────────────────────────────────────────
# Generated / runtime files
# ──────────────────────────────────────────────
colors.conf             # di-generate oleh matugen (dari wallpaper aktif)
scripts/quickshell/.cache/
scripts/quickshell/cache/
**/.run/
**/run/
**/*.pid
AGENT.md
CLAUDE.md
**/*.log

# ──────────────────────────────────────────────
# Backup files (dari refactor session)
# ──────────────────────────────────────────────
**/*.bak
**/*.backup
**/*.orig

# ──────────────────────────────────────────────
# Preview images yang bisa di-generate ulang
# ──────────────────────────────────────────────
# scripts/quickshell/guide/previews/

